# Copia este archivo como ".env.local" para probar las funciones de
# /api en tu máquina con `vercel dev`. Este archivo de ejemplo NO lleva
# llaves reales y sí se puede subir a git; el .env.local con las llaves
# de verdad está en .gitignore y nunca debe subirse.
#
# En producción, estas mismas variables se configuran en:
# Vercel > tu proyecto > Settings > Environment Variables

GEMINI_API_KEY=tu_api_key_de_gemini_aqui
RAPIDAPI_KEY=tu_api_key_de_rapidapi_aqui
